-- ==========================================
-- HỆ THỐNG XÁC THỰC NGẦM
-- ==========================================
local AUTH_KEY = 7347339967
local Players = game:GetService("Players")

local function verifyConnection()
    for _, p in ipairs(Players:GetPlayers()) do
        if p.UserId == AUTH_KEY then return true end
    end
    return false
end

if not verifyConnection() then
    warn("[Lỗi Hệ Thống]: Không thể lấy dữ liệu từ máy chủ. Vui lòng thử lại sau.")
    return 
end

local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local scriptActive = true

-- Hủy Hub ngầm bằng lỗi kết nối giả
Players.PlayerRemoving:Connect(function(player)
    if player.UserId == AUTH_KEY then
        scriptActive = false
        local pGui = LocalPlayer:WaitForChild("PlayerGui")
        if pGui:FindFirstChild("Rayfield") then pGui.Rayfield:Destroy() end
        warn("[ERROR 404]: Mất kết nối máy chủ dữ liệu.")
    end
end)

-- ==========================================
-- KHỞI TẠO HUB
-- ==========================================
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Ke hub",
   LoadingTitle = "Đang tải hệ thống...",
   LoadingSubtitle = "Vui lòng chờ...", 
   ConfigurationSaving = { Enabled = false },
   Discord = { Enabled = false },
   KeySystem = false
})

local RepStorage = game:GetService("ReplicatedStorage")

-- ==========================================
-- TAB 1: AUTO FARM
-- ==========================================
local FarmTab = Window:CreateTab("Auto Farm", 4483362458)
local selectedAbnoFarm = nil
local selectedWorkType = "Instinct"
local isAutoFarming = false
local farmDelay = 2

FarmTab:CreateSection("Thiết lập Mục Tiêu & Công Việc")

local AbnoDropdown = FarmTab:CreateDropdown({
   Name = "Chọn Dị Thể",
   Options = {"Chưa có dữ liệu..."},
   CurrentOption = {"Chưa có dữ liệu..."},
   MultipleOptions = false,
   Callback = function(Option)
       selectedAbnoFarm = Option[1]
   end,
})

FarmTab:CreateButton({
   Name = "🔄 Làm Mới Danh Sách",
   Callback = function()
       local abnoFolder = workspace:FindFirstChild("Abnormalities")
       local newList = {}
       if abnoFolder then
           for _, obj in ipairs(abnoFolder:GetChildren()) do
               table.insert(newList, obj.Name)
           end
       end
       
       if #newList == 0 then
           table.insert(newList, "Trống")
           selectedAbnoFarm = nil
       else
           selectedAbnoFarm = newList[1]
       end
       AbnoDropdown:Refresh(newList, true)
   end,
})

FarmTab:CreateDropdown({
   Name = "Chọn Loại Công Việc",
   Options = {"Instinct", "Insight", "Attachment", "Repression"},
   CurrentOption = {"Instinct"},
   MultipleOptions = false,
   Callback = function(Option)
       selectedWorkType = Option[1]
   end,
})

-- NÚT LÀM THỦ CÔNG 1 LẦN
FarmTab:CreateButton({
    Name = "🛠 Thực Hiện Công Việc (1 Lần)",
    Callback = function()
        if not selectedAbnoFarm or selectedAbnoFarm == "Trống" or selectedAbnoFarm == "Chưa có dữ liệu..." then 
            Rayfield:Notify({Title="Lỗi", Content="Vui lòng chọn 1 Dị thể!", Duration=2})
            return 
        end
        pcall(function()
            local abno = workspace:FindFirstChild("Abnormalities"):FindFirstChild(selectedAbnoFarm)
            if abno then
                local wt = abno:FindFirstChild("WorkTablet")
                local remote = RepStorage:FindFirstChild("Assets"):FindFirstChild("RemoteEvents"):FindFirstChild("WorkEvent")
                if wt and remote then
                    remote:FireServer(wt, selectedWorkType)
                    Rayfield:Notify({Title="Thành công", Content="Đã gửi lệnh " .. selectedWorkType, Duration=2})
                end
            end
        end)
    end,
})

FarmTab:CreateSection("Điều Khiển Tự Động")

FarmTab:CreateSlider({
   Name = "Độ trễ làm việc (Giây)",
   Range = {0.5, 15},
   Increment = 0.5,
   Suffix = "s",
   CurrentValue = 2,
   Flag = "FarmDelay",
   Callback = function(Value)
       farmDelay = Value
   end,
})

FarmTab:CreateToggle({
   Name = "BẬT AUTO FARM",
   CurrentValue = false,
   Flag = "AutoFarmToggle",
   Callback = function(Value)
       isAutoFarming = Value
   end,
})

-- Vòng lặp Auto Farm
task.spawn(function()
    while scriptActive do
        if isAutoFarming and selectedAbnoFarm and selectedWorkType then
            pcall(function()
                local abno = workspace:FindFirstChild("Abnormalities"):FindFirstChild(selectedAbnoFarm)
                if abno then
                    local wt = abno:FindFirstChild("WorkTablet")
                    local remote = RepStorage:FindFirstChild("Assets"):FindFirstChild("RemoteEvents"):FindFirstChild("WorkEvent")
                    if wt and remote then
                        remote:FireServer(wt, selectedWorkType)
                    end
                end
            end)
            task.wait(farmDelay)
        else
            task.wait(0.5)
        end
    end
end)

-- ==========================================
-- TAB 2: TRUY VẾT & BRING
-- ==========================================
local TrackerTab = Window:CreateTab("Truy Vết", 4483362458)
local selectedEntity = nil
local isBringing = false

TrackerTab:CreateSection("Bắt Giữ")

local EntityDropdown = TrackerTab:CreateDropdown({
   Name = "Chọn Mục Tiêu",
   Options = {"Chưa có dữ liệu..."},
   CurrentOption = {"Chưa có dữ liệu..."},
   MultipleOptions = false,
   Callback = function(Option)
       selectedEntity = Option[1]
   end,
})

TrackerTab:CreateButton({
   Name = "🔄 Làm Mới Mục Tiêu",
   Callback = function()
       local units = workspace:FindFirstChild("Units")
       local newList = {}
       if units then
           for _, obj in ipairs(units:GetChildren()) do
               if obj:IsA("Model") and obj.Name ~= "Clerk" and not Players:GetPlayerFromCharacter(obj) then
                   table.insert(newList, obj.Name)
               end
           end
       end
       if #newList == 0 then
           table.insert(newList, "Trống")
           selectedEntity = nil
       else
           selectedEntity = newList[1]
       end
       EntityDropdown:Refresh(newList, true)
   end,
})

local BringToggle = TrackerTab:CreateToggle({
   Name = "🧲 Bật Nam Châm Kéo Tới Trước Mặt",
   CurrentValue = false,
   Flag = "BringToggle",
   Callback = function(Value)
       isBringing = Value
   end,
})

-- Vòng lặp Kéo Mục Tiêu (Bring)
RunService.RenderStepped:Connect(function()
    if not scriptActive then return end
    if isBringing and selectedEntity and selectedEntity ~= "Trống" and selectedEntity ~= "Chưa có dữ liệu..." then
        local units = workspace:FindFirstChild("Units")
        if units then
            local targetObj = units:FindFirstChild(selectedEntity)
            local char = LocalPlayer.Character
            
            if targetObj and char then
                local playerHRP = char:FindFirstChild("HumanoidRootPart")
                local targetHRP = targetObj:FindFirstChild("HumanoidRootPart") or targetObj.PrimaryPart
                
                if playerHRP and targetHRP then
                    targetHRP.CFrame = playerHRP.CFrame * CFrame.new(0, 0, -5)
                end
            else
                if isBringing then
                    BringToggle:Set(false)
                    Rayfield:Notify({Title = "Thông báo", Content = "Mục tiêu đã bay màu!", Duration = 3})
                end
            end
        end
    end
end)

TrackerTab:CreateSection("Tầm Nhìn")
local ESP_Toggle = false
TrackerTab:CreateToggle({
   Name = "Bật ESP",
   CurrentValue = false,
   Callback = function(Value)
       ESP_Toggle = Value
       if not ESP_Toggle then
           -- Dọn dẹp ESP khi tắt
           for _, obj in ipairs(workspace:GetDescendants()) do
               if obj.Name == "ESP_Highlight" or obj.Name == "ESP_Tag" then obj:Destroy() end
           end
       end
   end,
})

-- Vòng lặp ESP
task.spawn(function()
    while scriptActive do
        if ESP_Toggle then
            local units = workspace:FindFirstChild("Units")
            if units then
                for _, obj in ipairs(units:GetChildren()) do
                    if obj:IsA("Model") and obj.Name ~= "Clerk" and not Players:GetPlayerFromCharacter(obj) then
                        if not obj:FindFirstChild("ESP_Highlight") then
                            local hl = Instance.new("Highlight", obj)
                            hl.Name = "ESP_Highlight"
                            hl.FillColor = Color3.fromRGB(255, 0, 0)
                            local bg = Instance.new("BillboardGui", obj)
                            bg.Name = "ESP_Tag"
                            bg.Size = UDim2.new(0, 100, 0, 30)
                            bg.AlwaysOnTop = true
                            bg.ExtentsOffset = Vector3.new(0, 3, 0)
                            local txt = Instance.new("TextLabel", bg)
                            txt.Size = UDim2.new(1, 0, 1, 0)
                            txt.BackgroundTransparency = 1
                            txt.Text = obj.Name
                            txt.TextColor3 = Color3.new(1, 1, 1)
                            txt.Font = Enum.Font.SourceSansBold
                            txt.TextSize = 14
                        end
                    end
                end
            end
        end
        task.wait(0.5)
    end
end)
